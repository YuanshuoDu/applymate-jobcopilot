{
  "name": "jobcopilot",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "test:all": "turbo test && (playwright test || true)",
    "build:all": "turbo build",
    "typecheck:all": "turbo typecheck && pnpm --filter @jobcopilot/worker exec tsc --noEmit --skipLibCheck && pnpm --filter @jobcopilot/shared exec tsc --noEmit --skipLibCheck"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "next": "^15.3.1",
    "turbo": "^2.5.4",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
