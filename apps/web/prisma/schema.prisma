// Prisma Schema �?ApplyMate AI
// Database: PostgreSQL (Supabase / Neon / self-hosted)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// NextAuth v5 adapter tables
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Core domain models
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // hashed, for credential login
  plan          Plan      @default(free)
  phone         String?
  location      String?
  linkedin      String?
  github        String?
  preferences   Json?     // { targetRoles, targetLocations, salaryExpectation, workAuthorization, openToRelocation, aiSettings }
  personaFields Json?     // PersonaField[] �?learned answers from form fills
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // M1 extensions
  onboardedAt        DateTime?
  onboardingGoals    String[]
  defaultTemplateId  String?
  defaultAccentColor String?
  defaultFontFamily  String?
  aiAutoPilot        String   @default("off")

  accounts       Account[]
  sessions       Session[]
  jobs           Job[]
  resumes        Resume[]
  activities     Activity[]
  agentConfig        AgentConfig?
  agentRoles         AgentRole[]
  customAgentRoles   CustomAgentRole[]
  agentRunQuestions  AgentRunQuestion[]
  resumeVersions ResumeVersion[]
  directions     Direction[]
  coverLetters   CoverLetter[]
}

enum Plan {
  free
  pro
  enterprise
}

model Job {
  id          String    @id @default(cuid())
  userId      String
  company     String
  logo        String?   // 2-letter abbreviation or image URL
  role        String
  location    String?
  status      JobStatus @default(saved)
  score       Int?      // AI match score 0-100
  url         String?   @db.Text
  description String?   @db.Text
  salary      String?
  source      String?   // linkedin | indeed | manual | agent
  notes        String?   @db.Text
  coverLetter  String?   @db.Text  // saved by Writer agent (deprecated — use CoverLetter table)
  analysisNote String?   @db.Text  // saved by Analyst agent (recommendation)
  keywords     String?   @db.Text  // ATS keywords extracted from JD during scoring
  appliedAt    DateTime?
  followUpAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // M1 extensions
  finalResumeId      String?
  finalCoverLetterId String?

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applyResults     ApplyResult[]
  activities       Activity[]
  finalResume      Resume?       @relation("JobFinalResume",   fields: [finalResumeId],      references: [id], onDelete: SetNull)
  finalCoverLetter CoverLetter?  @relation("JobFinalCL",       fields: [finalCoverLetterId], references: [id], onDelete: SetNull)
  adaptedResumes   Resume[]      @relation("JobAdaptedResumes")
  coverLetters     CoverLetter[]

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
}

enum JobStatus {
  saved
  applied
  review
  interview
  offer
  rejected
}

model Resume {
  id              String   @id @default(cuid())
  userId          String
  name            String
  content         Json     // ResumeContent JSON (see types.ts)
  templateId      String?
  templateOptions Json?    // TemplateOptions JSON { accentColor, fontFamily, density }
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // M1 extensions
  directionId    String?
  kind           String   @default("base")
  parentResumeId String?
  targetJobId    String?
  origin         String   @default("manual")
  basicsDetached Boolean  @default(false)

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions     ResumeVersion[]
  direction    Direction?      @relation(fields: [directionId], references: [id], onDelete: SetNull)
  parent       Resume?         @relation("ResumeLineage", fields: [parentResumeId], references: [id], onDelete: SetNull)
  derivatives  Resume[]        @relation("ResumeLineage")
  targetJob    Job?            @relation("JobAdaptedResumes", fields: [targetJobId], references: [id], onDelete: SetNull)
  coverLetters CoverLetter[]
  finalForJobs Job[]           @relation("JobFinalResume")

  @@index([userId])
  @@index([userId, directionId])
  @@index([targetJobId])
}

model ResumeVersion {
  id        String   @id @default(cuid())
  resumeId  String
  userId    String
  content   Json     // ResumeContent snapshot
  name      String   // resume name at time of snapshot
  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resumeId, createdAt(sort: Desc)])
  @@index([userId])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  jobId     String?
  type      ActivityType
  text      String
  color     String?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job?  @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
}

enum ActivityType {
  applied
  interview_scheduled
  offer_received
  rejected
  email_sent
  agent_action
  resume_tailored
  status_changed
  note_added
}

model AgentConfig {
  id                String   @id @default(cuid())
  userId            String   @unique
  isRunning         Boolean  @default(false)
  dailyLimit        Int      @default(10)
  minMatchScore     Int      @default(75)
  autoApply         Boolean  @default(false)
  requireApproval   Boolean  @default(true)
  targetLocations   String[]
  targetRoles       String[]
  excludeCompanies  String[]
  priorityCompanies String[]
  autoCoverLetter   Boolean  @default(false)
  coverTone         String   @default("professional")
  useTailoredCV     Boolean  @default(false)
  salaryMin         Int      @default(0)
  salaryMax         Int      @default(0)
  notifyApply       Boolean  @default(true)
  notifyReject      Boolean  @default(true)
  weeklySummary     Boolean  @default(false)
  followUpReminder  Boolean  @default(true)
  followUpDays      Int      @default(7)
  model             String   @default("claude-sonnet-4-6")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Agent Role Configs (one per role per user)
// ─────────────────────────────────────────────

enum AgentRoleType {
  scout
  analyst
  writer
  reviewer
  executor
  auditor
}

model AgentRole {
  id           String        @id @default(cuid())
  userId       String
  role         AgentRoleType
  enabled      Boolean       @default(true)
  provider     String        @default("anthropic")
  model        String
  apiKey       String?
  systemPrompt String?       @db.Text  // user-customizable instructions
  lastRunAt    DateTime?
  lastResult   Json?         // { count, durationMs, summary }
  totalRuns    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
}

model AtsEmployer {
  id        Int      @id @default(autoincrement())
  atsType   String
  slug      String
  name      String?
  firstSeen DateTime @default(now())
  lastSeen  DateTime @updatedAt
  jobCount  Int      @default(0)

  @@unique([atsType, slug])
  @@map("ats_employers")
}

model ApplyResult {
  id         Int      @id @default(autoincrement())
  userId     String   @map("user_id")
  jobId      String   @map("job_id")
  status     String                     // submitted | manual | failed | dry-run
  mode       String                     // unattended | assisted
  atsType    String?  @map("ats_type")
  flowUsed   String?  @map("flow_used")
  error      String?
  durationMs Int?     @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("apply_results")
}

// ─────────────────────────────────────────────
// Agent Run Questions (pause/resume queue)
// ─────────────────────────────────────────────

model AgentRunQuestion {
  id          String    @id @default(cuid())
  userId      String
  runId       String
  stage       String
  question    String    @db.Text
  options     Json
  answer      String?
  autonomous  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  answeredAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, runId])
  @@index([userId, runId, answeredAt])
}

// ─────────────────────────────────────────────
// Custom Agent Roles (user-defined pipeline nodes)
// ─────────────────────────────────────────────

model CustomAgentRole {
  id           String   @id @default(cuid())
  userId       String
  name         String
  icon         String   @default("🧩")
  description  String?
  systemPrompt String?  @db.Text
  provider     String   @default("anthropic")
  model        String   @default("claude-haiku-4-5-20251001")
  insertAfter  String   @default("auditor")
  enabled      Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// M1: Direction + CoverLetter models
// ─────────────────────────────────────────────

model Direction {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumes Resume[]

  @@unique([userId, name])
  @@index([userId])
}

model CoverLetter {
  id              String   @id @default(cuid())
  userId          String
  jobId           String
  resumeId        String?
  content         String   @db.Text
  tone            String   @default("professional")
  templateId      String?
  templateOptions Json?
  origin          String   @default("manual")
  isFinal         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  finalForJobs Job[] @relation("JobFinalCL")

  @@index([userId, jobId])
  @@index([jobId, isFinal])
}
