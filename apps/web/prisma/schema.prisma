// Prisma Schema — ApplyMate AI
// Database: PostgreSQL (Supabase / Neon / self-hosted)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// NextAuth v5 adapter tables
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Core domain models
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // hashed, for credential login
  plan          Plan      @default(free)
  phone         String?
  location      String?
  linkedin      String?
  github        String?
  preferences   Json?     // { targetRoles, targetLocations, salaryExpectation, workAuthorization, openToRelocation, aiSettings }
  personaFields Json?     // PersonaField[] — learned answers from form fills
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  jobs        Job[]
  resumes     Resume[]
  activities  Activity[]
  agentConfig   AgentConfig?
  agentRoles    AgentRole[]
  resumeVersions ResumeVersion[]
}

enum Plan {
  free
  pro
  enterprise
}

model Job {
  id          String    @id @default(cuid())
  userId      String
  company     String
  logo        String?   // 2-letter abbreviation or image URL
  role        String
  location    String?
  status      JobStatus @default(saved)
  score       Int?      // AI match score 0-100
  url         String?   @db.Text
  description String?   @db.Text
  salary      String?
  source      String?   // linkedin | indeed | manual | agent
  notes        String?   @db.Text
  coverLetter  String?   @db.Text  // saved by Writer agent
  analysisNote String?   @db.Text  // saved by Analyst agent (recommendation)
  appliedAt    DateTime?
  followUpAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
}

enum JobStatus {
  saved
  applied
  review
  interview
  offer
  rejected
}

model Resume {
  id              String   @id @default(cuid())
  userId          String
  name            String
  content         Json     // ResumeContent JSON (see types.ts)
  templateId      String?
  templateOptions Json?    // TemplateOptions JSON { accentColor, fontFamily, density }
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions ResumeVersion[]

  @@index([userId])
}

model ResumeVersion {
  id        String   @id @default(cuid())
  resumeId  String
  userId    String
  content   Json     // ResumeContent snapshot
  name      String   // resume name at time of snapshot
  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resumeId, createdAt(sort: Desc)])
  @@index([userId])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  jobId     String?
  type      ActivityType
  text      String
  color     String?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job?  @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
}

enum ActivityType {
  applied
  interview_scheduled
  offer_received
  rejected
  email_sent
  agent_action
  resume_tailored
  status_changed
  note_added
}

model AgentConfig {
  id                String   @id @default(cuid())
  userId            String   @unique
  isRunning         Boolean  @default(false)
  dailyLimit        Int      @default(10)
  minMatchScore     Int      @default(75)
  autoApply         Boolean  @default(false)
  requireApproval   Boolean  @default(true)
  targetLocations   String[]
  targetRoles       String[]
  excludeCompanies  String[]
  priorityCompanies String[]
  autoCoverLetter   Boolean  @default(false)
  coverTone         String   @default("professional")
  useTailoredCV     Boolean  @default(false)
  salaryMin         Int      @default(0)
  salaryMax         Int      @default(0)
  notifyApply       Boolean  @default(true)
  notifyReject      Boolean  @default(true)
  weeklySummary     Boolean  @default(false)
  followUpReminder  Boolean  @default(true)
  followUpDays      Int      @default(7)
  model             String   @default("claude-sonnet-4-6")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Agent Role Configs (one per role per user)
// ─────────────────────────────────────────────

enum AgentRoleType {
  scout
  analyst
  writer
  reviewer
  executor
  auditor
}

model AgentRole {
  id           String        @id @default(cuid())
  userId       String
  role         AgentRoleType
  enabled      Boolean       @default(true)
  provider     String        @default("anthropic")
  model        String
  apiKey       String?
  systemPrompt String?       @db.Text  // user-customizable instructions
  lastRunAt    DateTime?
  lastResult   Json?         // { count, durationMs, summary }
  totalRuns    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
}

model AtsEmployer {
  id        Int      @id @default(autoincrement())
  atsType   String
  slug      String
  name      String?
  firstSeen DateTime @default(now())
  lastSeen  DateTime @updatedAt
  jobCount  Int      @default(0)

  @@unique([atsType, slug])
  @@map("ats_employers")
}
