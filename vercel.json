{
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @jobcopilot/web exec prisma generate && pnpm --filter @jobcopilot/web build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "pnpm install --ignore-scripts",
  "devCommand": "pnpm --filter @jobcopilot/web dev",
  "crons": [
    {
      "path": "/api/agent/automations/due",
      "schedule": "0 8 * * *"
    }
  ]
}
